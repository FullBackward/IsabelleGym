#!/usr/bin/env bash
#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
ROOT="${SCRIPT_DIR}/../../../"
REPO_ROOT="${ROOT}/app"
ISABELLE="${ROOT}/opt/isabelle/bin/isabelle"

fix_settings_tree() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  find "$dir" -path '*/etc/settings' -type f -exec sed -i 's/\r$//' {} \;
}

ISABELLE_IDENTIFIER="$(ISABELLE_COMPONENTS='' "$ISABELLE" getenv -b ISABELLE_IDENTIFIER 2>/dev/null || echo Isabelle2025-2)"
CONTRIB_DIR="${HOME}/.isabelle/${ISABELLE_IDENTIFIER}/contrib"

# Fix any repo-side settings
fix_settings_tree "$REPO_ROOT"

# Fix stale user contrib settings before using components
fix_settings_tree "$CONTRIB_DIR"

"$ISABELLE" components -u "$REPO_ROOT/repl/Admin"
"$ISABELLE" component_py4j
"$ISABELLE" component_spliff

# IMPORTANT: fix newly created contrib settings again
fix_settings_tree "$CONTRIB_DIR"

"$ISABELLE" components -u "$REPO_ROOT/repl"

echo "Init done. REPO_ROOT=$REPO_ROOT  ISABELLE=$ISABELLE  ID=$ISABELLE_IDENTIFIER"