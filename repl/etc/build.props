title = REPL
module = lib/repl.jar
services = repl.Scala_Functions
requirements = \
  env:ISABELLE_SCALA_JAR 
sources = \
  src/main/scala/repl/document_utils.scala \
    src/main/scala/repl/edit_utils.scala \
  src/main/scala/repl/repl_backend.scala \
  src/main/scala/repl/repl_backend_gateway.scala \
  src/main/scala/repl/repl_ml_communication.scala \
  src/main/scala/repl/repl_output.scala \
  src/main/scala/repl/vector_env.scala \
  src/main/scala/repl/repl_session.scala \
  src/main/scala/repl/server_utils.scala \
  src/main/scala/repl/session_manager.scala \
  src/main/scala/repl/thy_info.scala \
  src/main/scala/repl/thy_parsing.scala \
  src/main/scala/repl/thy_status.scala
main = repl.GatewayApp
